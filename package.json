{
  "name": "openfox-google-antigravity",
  "version": "1.0.0",
  "description": "Google Antigravity (Cloud Code Assist) account provider plugin for OpenFox",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "openfox": {
    "apiVersion": 1,
