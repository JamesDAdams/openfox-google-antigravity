    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "author": "James Adams",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JamesDAdams/openfox-google-antigravity.git"
  },
  "peerDependencies": {
    "openfox": ">=2.0.56 <3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.7.3",
    "tsup": "^8.4.0",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "engines": {
    "node": ">=19"
  }
}